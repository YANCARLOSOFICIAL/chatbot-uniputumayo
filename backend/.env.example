# Database
DATABASE_URL=postgresql+asyncpg://chatbot_user:chatbot_password@localhost:5433/chatbot_db

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=qwen3:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=gemma4:e4b

# OpenAI
OPENAI_API_KEY=sk-your-key-here
OPENAI_DEFAULT_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# LLM Configuration
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_TEMPERATURE=0.05
DEFAULT_MAX_TOKENS=2048

# RAG Configuration
CHUNK_SIZE=512
CHUNK_OVERLAP=77
RAG_TOP_K=10
# nomic-embed-text en docs en español puntúa ~0.4-0.65; 0.35 captura lo relevante.
# Si cambias a un embedding_provider distinto, reevalúa este umbral.
RAG_SCORE_THRESHOLD=0.35
RAG_CANDIDATES_MULTIPLIER=3
RAG_HYDE_ENABLED=true
RAG_DIVERSITY_ENABLED=true
# NO cambiar sin migrar la dimensión del vector en pgvector (ver embedding_dimensions)
EMBEDDING_PROVIDER=ollama
# nomic-embed-text=768 | text-embedding-3-small=1536
EMBEDDING_DIMENSIONS=768

# Answer cache (respuestas completas cacheadas por similitud semántica de preguntas)
ANSWER_CACHE_ENABLED=true
ANSWER_CACHE_EMBEDDING_MODEL=embeddinggemma
ANSWER_CACHE_SIMILARITY_THRESHOLD=0.65
ANSWER_CACHE_TTL_SECONDS=2592000
ANSWER_CACHE_MAX_ENTRIES=1000

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# Reverse-proxy hops in front of the backend (nginx=1) — used to pick the
# trustworthy entry in X-Forwarded-For for rate limiting.
TRUSTED_PROXY_COUNT=1

# Document Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# Redis (opcional — habilita caché RAG/answer-cache persistente entre reinicios).
# Deja vacío para usar el fallback en memoria.
REDIS_URL=

# Auth / JWT — OBLIGATORIO cambiar estos valores en cualquier despliegue real
JWT_SECRET=change-me-to-a-long-random-value-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480
ADMIN_EMAIL=admin@iup.edu.co
ADMIN_PASSWORD=change-me-in-production
