# ============================================
# Variables de entorno - Producción
# ============================================
# Copiar este archivo como .env.prod y configurar los valores
# En Portainer se pueden configurar directamente en el Stack
# ============================================

# ── Tag de las imágenes (default: latest) ──
TAG=latest

# ── Base de datos ──
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=chatbot_db

# ── LLM Ollama ──
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── LLM OpenAI (opcional) ──
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Proveedor LLM por defecto ──
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_TEMPERATURE=0.3
DEFAULT_MAX_TOKENS=1024

# ── RAG ──
CHUNK_SIZE=512
CHUNK_OVERLAP=77
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.7
EMBEDDING_DIMENSIONS=768

# ── CORS (para producción usar el dominio/IP del servidor) ──
CORS_ORIGINS=*

# ── Uploads ──
MAX_UPLOAD_SIZE_MB=50

# ── Logs ──
LOG_LEVEL=info

# ── Seguridad (CAMBIAR EN PRODUCCIÓN) ──
JWT_SECRET=CAMBIAR_A_UN_SECRET_SEGURO_ALEATORIO
ADMIN_EMAIL=admin@iup.edu.co
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

# ── Puerto Nginx ──
NGINX_PORT=80
