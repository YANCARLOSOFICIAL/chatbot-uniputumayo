# ============================================
# Variables de entorno - Producción (VM Ubuntu)
# ============================================
# Copiar este archivo como .env.prod y configurar los valores
#   cp .env.prod.example .env.prod
#   nano .env.prod
# ============================================

# ── Base de datos ──
POSTGRES_USER=chatbot_user
POSTGRES_PASSWORD=CAMBIAR_PASSWORD_SEGURO
POSTGRES_DB=chatbot_db

# ── Ollama (LLM local - 64 GB RAM disponible) ──
# Modelos recomendados para 64 GB:
#   - qwen2.5:7b   (~5 GB)  → Rápido, buen español
#   - llama3.1:8b   (~5 GB)  → Muy bueno general
#   - gemma3:12b    (~8 GB)  → Mejor calidad, más lento
#   - qwen2.5:32b  (~20 GB) → Máxima calidad si tienes paciencia
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_VISION_MODEL=gemma3:4b

# ── OpenAI (fallback opcional, requiere API key) ──
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Proveedor LLM por defecto ──
# Opciones: "ollama" (gratis, local) | "openai" (pago, API)
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_TEMPERATURE=0.1
DEFAULT_MAX_TOKENS=2048

# ── RAG ──
CHUNK_SIZE=512
CHUNK_OVERLAP=77
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.35
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSIONS=768

# ── CORS ──
# Agregar tu dominio si lo tienes, separado por comas
CORS_ORIGINS=http://185.236.182.93,http://185.236.182.93:80,http://localhost

# ── Uploads ──
MAX_UPLOAD_SIZE_MB=50

# ── Logs ──
LOG_LEVEL=info

# ── Seguridad (¡CAMBIAR EN PRODUCCIÓN!) ──
JWT_SECRET=CAMBIAR_A_UN_SECRET_SEGURO_ALEATORIO
ADMIN_EMAIL=admin@iup.edu.co
ADMIN_PASSWORD=CAMBIAR_PASSWORD_ADMIN

# ── Puerto Nginx ──
NGINX_PORT=80
